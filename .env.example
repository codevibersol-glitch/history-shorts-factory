# History Shorts Factory - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# GROK IMAGINE VIDEO API (xAI)
# ============================================
# Get your API key from: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# ============================================
# YOUTUBE API CREDENTIALS
# ============================================
# Download from: https://console.cloud.google.com/apis/credentials
# Place the file as: client_secrets.json in the project root
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# YouTube API Scopes (usually don't need to change)
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.upload

# ============================================
# DEFAULT SETTINGS
# ============================================
# Default topic if not specified via CLI
DEFAULT_TOPIC=World War II

# Video duration in seconds (45-60 recommended for Shorts)
VIDEO_DURATION=55

# Output directory for generated videos
OUTPUT_DIR=./output

# Logs directory
LOGS_DIR=./logs

# ============================================
# TTS SETTINGS (edge-tts)
# ============================================
# Available voices: en-US-ChristopherNeural, en-US-GuyNeural, en-GB-RyanNeural, etc.
# Full list: edge-tts --list-voices
TTS_VOICE=en-US-ChristopherNeural

# TTS rate (percentage with +/- sign, e.g., +10% or -5%)
TTS_RATE=+0%

# TTS volume (percentage with +/- sign)
TTS_VOLUME=+0%

# ============================================
# VIDEO SETTINGS
# ============================================
# Resolution: 720p or 1080p
VIDEO_RESOLUTION=720p

# Aspect ratio (9:16 for Shorts/Reels/TikTok)
ASPECT_RATIO=9:16

# FPS for generated videos
VIDEO_FPS=30

# ============================================
# SUBTITLE SETTINGS
# ============================================
# Subtitle font size
SUBTITLE_FONT_SIZE=48

# Subtitle font color (yellow with black outline is classic)
SUBTITLE_COLOR=yellow

# Subtitle outline color
SUBTITLE_OUTLINE_COLOR=black

# Subtitle outline width (1-4)
SUBTITLE_OUTLINE_WIDTH=2

# ============================================
# UPLOAD SETTINGS
# ============================================
# Default upload privacy status
UPLOAD_PRIVACY=public

# YouTube category ID (22 = People & Blogs, 27 = Education, 25 = News & Politics)
YOUTUBE_CATEGORY_ID=22

# Default tags (comma-separated)
DEFAULT_TAGS=history,shorts,facts,educational,war,battle,interesting facts

# ============================================
# ADVANCED
# ============================================
# Enable debug mode (verbose logging)
DEBUG=false

# Maximum retries for API calls
MAX_RETRIES=3

# Retry delay multiplier (exponential backoff)
RETRY_DELAY=1.0
